{
  "manifest_version": 3,
  "name": "WHYL - While AI Thinks, You Earn",
  "version": "1.0.0",
  "description": "Earn credits during long AI wait times without interrupting your workflow.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://cursor.com/*",
    "https://replit.com/*",
    "https://lovable.dev/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://manus.im/*",
    "http://localhost:3001/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://cursor.com/*",
        "https://replit.com/*",
        "https://lovable.dev/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://manus.im/*"
      ],
      "js": ["net-probe.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://cursor.com/*",
        "https://replit.com/*",
        "https://lovable.dev/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://manus.im/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.css", "ad-player.html"],
      "matches": ["https://*/*"]
    }
  ]
}
