{
  "manifest_version": 3,
  "name": "Whyl — Earn While AI Thinks",
  "version": "0.1.0",
  "description": "Whyl turns AI wait time into rewards. Earn credits while ChatGPT thinks.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content/chatgpt.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    }
  ]
}
